# --- Pinecone (vector store) ---
PINECONE_API_KEY=
INDEX_NAME=legal_ai_rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=law-corpus

# --- Case Content API (ALQAC2026) ---
ALQAC_API_BASE_URL=https://alqac-api.ngrok.pro
ALQAC_TOKEN=alqac_xxxxxxxxxxxxxxxxxxxxxxxx
ALQAC_MIN_REQUEST_INTERVAL_SEC=5.0
DEFAULT_MAX_API_CALLS_PER_CASE=8

# --- Models ---
EMBEDDING_MODEL_NAME=AITeamVN/Vietnamese_Embedding
EMBEDDING_DIM=1024
RERANKER_MODEL_NAME=AITeamVN/Vietnamese_Reranker
GENERATION_MODEL_NAME=Qwen/Qwen3.5-0.8B
GENERATION_ATTN_IMPL=sdpa
GENERATION_MAX_NEW_TOKENS_DEFAULT=500
LEGALRAG_DEVICE=cuda

# --- NER / Query decomposition (thay HyDE) ---
NER_MODEL_NAME=NlpHUST/ner-vietnamese-electra-base
QUERY_DECOMPOSITION_ENABLED=true
QUERY_DECOMPOSITION_MAX_SUBQUERIES=4
RRF_WEIGHT_STANDARD=1.0
RRF_WEIGHT_AGENT=2.0

# --- Retrieval evaluator loop ---
RETRIEVAL_EVALUATOR_ENABLED=true
RETRIEVAL_EVALUATOR_SCORE_THRESHOLD=0.75

# --- Chunking / digest ---
CHILD_MAX_CHARS=900
TOP_N_EVIDENCE_FOR_DIGEST=5
CASE_DIGEST_MAX_NEW_TOKENS=220

# --- Paths ---
LEGALRAG_DATA_DIR=./data
LAW_CORPUS_PATH=./data/corpus_law_pub.json
TEST_SET_PATH=./data/ALQAC2026_public_test.json
SUBMISSION_OUT_PATH=./submission.json
