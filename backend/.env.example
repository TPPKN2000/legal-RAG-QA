# --- Pinecone (vector store) ---
PINECONE_API_KEY=
INDEX_NAME=legal-ai-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=law-corpus

# --- Case Content API (ALQAC2026) ---
ALQAC_API_BASE_URL=https://alqac-api.ngrok.pro
ALQAC_TOKEN=alqac_xxxxxxxxxxxxxxxxxxxxxxxx
ALQAC_MIN_REQUEST_INTERVAL_SEC=5.0

# --- Models ---
EMBEDDING_MODEL_NAME=AITeamVN/Vietnamese_Embedding
EMBEDDING_DIM=1024
RERANKER_MODEL_NAME=AITeamVN/Vietnamese_Reranker
GENERATION_MODEL_NAME=Qwen/Qwen3-8B
LEGALRAG_DEVICE=cuda

# --- Paths (defaults shown; override if your layout differs) ---
LEGALRAG_DATA_DIR=./data
LAW_CORPUS_PATH=./data/corpus_law_pub.json
TEST_SET_PATH=./data/ALQAC2026_public_test.json
SUBMISSION_OUT_PATH=./submission.json
